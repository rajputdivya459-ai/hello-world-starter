# GymOS environment configuration
# These values are auto-injected in Lovable Cloud projects.

VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# App mode controls the data provider used at runtime.
#   demo       → localStorage + seedDemoData (default, current behavior)
#   production → Supabase (Phase 4+; not yet wired)
# Runtime override: localStorage.setItem('gymos_app_mode', 'demo'|'production')
VITE_APP_MODE=demo
